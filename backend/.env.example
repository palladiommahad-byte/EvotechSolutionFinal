# Database Configuration
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_db_name

# JWT Configuration
JWT_SECRET=your_jwt_secret_key

# Server Configuration
PORT=3000

# Automatic database backup (daily at 02:00 in the selected time zone)
BACKUP_TIMEZONE=Africa/Casablanca
DAILY_BACKUP_CRON=0 2 * * *

# Google Drive cloud backup. Create a Web application OAuth client in Google
# Cloud, enable the Drive API, and add the redirect URI shown below there.
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:3000/api/settings/google-drive/callback
# Public URL of the frontend after Google authorization is complete.
FRONTEND_URL=http://localhost:8080
# Optional: a dedicated 32+ character secret for encrypting the Drive refresh token.
# BACKUP_ENCRYPTION_KEY=
